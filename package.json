{
  "name": "rss-commander",
  "version": "1.0.0",
  "description": "RSS Commander — Signal Intelligence Terminal. Standalone RSS aggregator for security professionals.",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"vite\" --names \"PROXY,VITE\" --prefix-colors \"cyan,magenta\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "server": "node server/index.js",
    "ticker": "vite --port 5175"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "date-fns": "^3.3.1",
    "dompurify": "^3.1.5",
    "framer-motion": "^11.2.10",
    "lucide-react": "^0.378.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  }
}
